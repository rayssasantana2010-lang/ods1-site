<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meu Site Profissional</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        /* --- CSS: O VISUAL DO SITE --- */
        :root {
            --bg-color: #ffffff;
            --text-color: #333333;
            --primary-color: #6c63ff;
            --nav-bg: #f8f9fa;
        }

        /* Cores do Modo Escuro */
        .dark-theme {
            --bg-color: #1a1a1a;
            --text-color: #ffffff;
            --nav-bg: #2d2d2d;
        }

        body {
            margin: 0;
            font-family: 'Poppins', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            transition: 0.3s;
        }

        header {
            background-color: var(--nav-bg);
            padding: 1rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo { font-weight: 600; font-size: 1.5rem; color: var(--primary-color); }

        nav ul { display: flex; list-style: none; gap: 20px; }
        nav a { text-decoration: none; color: var(--text-color); font-weight: 400; }

        .container { padding: 50px 10%; text-align: center; }

        .btn-theme {
            padding: 8px 15px;
            cursor: pointer;
            border: none;
            background: var(--primary-color);
            color: white;
            border-radius: 20px;
        }

        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }

        .card {
            background: var(--nav-bg);
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        footer {
            margin-top: 50px;
            padding: 20px;
            background: var(--nav-bg);
            text-align: center;
        }

        /* Responsividade para celular */
        @media (max-width: 600px) {
            nav ul { display: none; } /* Simplicidade: esconde o menu no mobile */
        }
    </style>
</head>
<body class="">

    <header>
        <div class="logo">Rayssa's Site</div>
        <nav>
            <ul>
                <li><a href="#inicio">Início</a></li>
                <li><a href="#projetos">Projetos</a></li>
                <li><button class="btn-theme" id="theme-toggle">Trocar Tema</button></li>
            </ul>
        </nav>
    </header>

    <div class="container" id="inicio">
        <h1>Bem-vindo ao meu novo site!</h1>
        <p>Este site foi atualizado com HTML, CSS e JavaScript integrados.</p>
        
        <div class="card-grid" id="projetos">
            <div class="card">
                <h3>Funcionalidade 1</h3>
                <p>Modo Escuro ativado via JavaScript.</p>
            </div>
            <div class="card">
                <h3>Funcionalidade 2</h3>
                <p>Design Responsivo que se ajusta à tela.</p>
            </div>
            <div class="card">
                <h3>Funcionalidade 3</h3>
                <p>Fontes modernas do Google Fonts.</p>
            </div>
        </div>
    </div>

    <footer>
        <p>&copy; 2026 Desenvolvido por Rayssa Santana</p>
    </footer>

    <script>
        const themeBtn = document.getElementById('theme-toggle');
        const body = document.body;

        // Função para trocar o tema
        themeBtn.addEventListener('click', () => {
            body.classList.toggle('dark-theme');
            
            // Salva a preferência do usuário
            if (body.classList.contains('dark-theme')) {
                localStorage.setItem('theme', 'dark');
            } else {
                localStorage.setItem('theme', 'light');
            }
        });

        // Verifica se o usuário já tinha escolhido um tema antes
        if (localStorage.getItem('theme') === 'dark') {
            body.classList.add('dark-theme');
        }
    </script>
</body>
</html>
